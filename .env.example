# ── LOCAL DEV: Token-only (simplest, no OAuth setup) ──
# GitHub Settings > Developer Settings > Personal access tokens
# Create a token with "read:user" scope. Add it here; no login required on localhost.
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── PRODUCTION / OAuth login (optional if using token above locally) ──
# Create an app at GitHub Settings > Developer Settings > OAuth Apps
# GITHUB_CLIENT_ID=your_oauth_client_id_here
# GITHUB_CLIENT_SECRET=your_oauth_client_secret_here

# Flask session encryption (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_random_secret_key_here

# ── SHARE LINKS (optional; auto-added when you connect Upstash Redis in Vercel) ──
# For local dev with share: copy from Vercel project env or Upstash console
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=your_token
